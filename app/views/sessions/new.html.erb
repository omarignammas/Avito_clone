<!-- Partie droite (formulaire de connexion) -->
<div class="flex-1 flex items-center justify-center p-6">
  <div class="w-full max-w-md">
    <h1 class="text-2xl font-bold text-gray-800 mb-2">Connectez-vous à Avito</h1>
    <p class="text-gray-500 text-sm mb-8">Utilisez vos identifiants pour vous connecter</p>
    
    <% if flash[:error] %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <%= flash[:error] %>
      </div>
    <% end %>
    
    <%= form_with(url: login_path, method: :post, local: true, class: "space-y-4") do |f| %>
      <!-- Email -->
      <div class="space-y-2">
        <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700" %>
        <div class="relative">
          <%= f.email_field :email, class: "block w-full rounded-md border border-gray-300 shadow-sm py-3 px-4 placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500", placeholder: "exemple@email.com", required: true %>
        </div>
      </div>
      
      <!-- Mot de passe -->
      <div class="space-y-2">
        <%= f.label :password, "Mot de passe", class: "block text-sm font-medium text-gray-700" %>
        <div class="relative">
          <%= f.password_field :password, class: "block w-full rounded-md border border-gray-300 shadow-sm py-3 px-4 placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500", placeholder: "Votre mot de passe", required: true %>
        </div>
      </div>
      
      <!-- Numéro de téléphone -->
      <div class="space-y-2">
        <%= f.label :phone_number, "Numéro de téléphone", class: "block text-sm font-medium text-gray-700" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
            <span class="inline-flex items-center bg-red-600 text-white rounded-l px-3 h-full border border-r-0 border-gray-300">
              +212
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </div>
          <%= f.text_field :phone_number, class: "pl-20 block w-full rounded-md border border-gray-300 shadow-sm py-3 px-4 placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500", placeholder: "Ex: 062333321**", required: true %>
        </div>
      </div>
      
      <div class="flex justify-end">
        <%= link_to "Mot de passe oublié ?", "#", class: "text-sm text-blue-600 hover:text-blue-800" %>
      </div>
      
      <div>
        <%= f.submit "Se connecter", class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-500 hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
      </div>
    <% end %>
    
    <div class="mt-6">
      <div class="relative">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-300"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-white text-gray-500">Ou avec</span>
        </div>
      </div>
      
      <div class="mt-6">
        <%= link_to '/auth/google_oauth2', class: "w-full flex items-center justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm bg-white hover:bg-gray-50", method: :post do %>
          <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.24 10.285V14.4h6.806c-.275 1.765-2.056 5.174-6.806 5.174-4.095 0-7.439-3.389-7.439-7.574s3.345-7.574 7.439-7.574c2.33 0 3.891.989 4.785 1.849l3.254-3.138C18.189 1.186 15.479 0 12.24 0c-6.635 0-12 5.365-12 12s5.365 12 12 12c6.926 0 11.52-4.869 11.52-11.726 0-.788-.085-1.39-.189-1.989H12.24z" fill="#4285F4"/>
          </svg>
          Se connecter avec Google
        <% end %>
      </div>
    </div>
    
    <div class="mt-6 text-center">
      <p class="text-sm text-gray-600">Vous n'avez pas de compte? <%= link_to "S'inscrire", signup_path, class: "text-blue-600 hover:text-blue-800" %></p>
    </div>
  </div>
</div>