<!-- Search section -->
<div class="container mx-auto px-4 py-6">
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="flex flex-col md:flex-row">
      <!-- Search input -->
      <div class="flex-1 p-2">
        <input type="text" placeholder="Que recherchez-vous ?" class="w-full px-4 py-3 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" />
      </div>
      
      <!-- Categories dropdown -->
      <div class="w-full md:w-64 p-2">
        <button class="w-full flex items-center justify-between px-4 py-3 bg-white border rounded-md">
          <div class="flex items-center">
            <svg class="w-5 h-5 text-blue-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <span>Toutes les catégories</span>
          </div>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
      
      <!-- Location dropdown -->
      <div class="w-full md:w-64 p-2">
        <button class="w-full flex items-center justify-between px-4 py-3 bg-white border rounded-md">
          <div class="flex items-center">
            <svg class="w-5 h-5 text-gray-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span>Choisir ville - secteur</span>
          </div>
        </button>
      </div>
      
      <!-- Search button -->
      <div class="p-2">
        <button class="w-full px-6 py-3 bg-blue-500 text-white font-medium rounded-md hover:bg-blue-600">
          Rechercher
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Main categories -->
<div class="container mx-auto px-4 py-6">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <!-- Immobilier category -->
    <div class="bg-blue-50 p-6 rounded-lg flex items-center">
      <div class="bg-blue-100 p-3 rounded-lg mr-4">
        <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
        </svg>
      </div>
      <h3 class="text-lg font-medium">Immobilier</h3>
    </div>
    
    <!-- Véhicules category -->
    <div class="bg-red-50 p-6 rounded-lg flex items-center">
      <div class="bg-red-100 p-3 rounded-lg mr-4">
        <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
        </svg>
      </div>
      <h3 class="text-lg font-medium">Véhicules</h3>
    </div>
    
    <!-- Marketplace category -->
    <div class="bg-green-50 p-6 rounded-lg flex items-center">
      <div class="bg-green-100 p-3 rounded-lg mr-4">
        <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
        </svg>
      </div>
      <h3 class="text-lg font-medium">Marketplace</h3>
    </div>
    
    <!-- Emplois et Services category -->
    <div class="bg-purple-50 p-6 rounded-lg flex items-center">
      <div class="bg-purple-100 p-3 rounded-lg mr-4">
        <svg class="w-6 h-6 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
      </div>
      <h3 class="text-lg font-medium">Emplois et Services</h3>
    </div>
  </div>
</div>

