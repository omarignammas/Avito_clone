<div class="premium-listings-container">
  <div class="premium-listings-wrapper">
    <div class="premium-listings-inner">
      <header class="premium-listings-header">
        <div class="premium-listings-title-container">
          <h2 class="premium-listings-title">Notre Annonces premium</h2>
        </div>
      </header>
      <section class="premium-listings-section">
        <div class="premium-listings-content">
          <div class="premium-listings-carousel">
            <div class="premium-listings-carousel-inner" dir="ltr">
              <button aria-label="Annonce précédente" class="carousel-prev-button">
                <svg class="carousel-arrow-icon" height="19" width="19" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <title>Annonce précédente</title>
                  <path d="M18.973 10.77A1.03 1.03 0 0120 11.795a1.03 1.03 0 01-1.027 1.027H7.503l5.001 5.02a1.023 1.023 0 11-1.447 1.449L4.3 12.515c-.4-.4-.4-1.048 0-1.448L11.067 4.3c.4-.4 1.047-.4 1.448 0 .4.4.4 1.058 0 1.458L7.504 10.77h11.47z"></path>
                </svg>
              </button>
              <div class="carousel-slide-container">
                <div class="carousel-slides">
                  <% @listings.each_with_index do |listing, index| %>
                    <div data-index="<%= index %>" class="carousel-slide" tabindex="-1" aria-hidden="false">
                      <div class="listing-card">
                        <a target="_self" href="<%= listing_path(listing) %>" class="listing-link">
                          <div class="listing-header">
                            <div class="listing-user-info">
                              <div class="listing-user-avatar">
                              <% if listing.user.avatar.attached? %>
                              <%= image_tag listing.user.avatar, class: "avatar-image" %>
                              <% else %>
                              <img src="/phoenix-assets/imgs/profile/avatar.svg" class="avatar-image" />
                            <% end %>
                            
                              </div>
                              <div class="listing-user-details">
                                <div class="listing-username">
                                  <p class="username-text" font-weight="600"><%= listing.user.username %></p>
                                </div>
                                <div class="listing-time">
                                  <svg class="clock-icon" height="12" width="12" viewBox="0 0 9 9" xmlns="http://www.w3.org/2000/svg">
                                    <title>ClockOutline Icon</title>
                                    <g clip-path="url(#clip0_442_9017)">
                                      <path d="M8.293 4.364a4.147 4.147 0 11-8.276-.376l.688.062a3.453 3.453 0 00.569 2.234A3.456 3.456 0 103.833.924L3.77.233a4.151 4.151 0 014.523 4.13zM1.957 1.691l-.438-.534a4.19 4.19 0 00-.58.581l.534.437a3.46 3.46 0 01.484-.484zm1.202-.639L2.962.391a4.141 4.141 0 00-.76.31l.324.61c.202-.107.414-.193.633-.259zM1.093 2.746l-.61-.325a4.151 4.151 0 00-.31.76l.662.197c.065-.219.151-.431.258-.633zm2.708-.455V3.77a.691.691 0 00-.25.25H2.42v.691h1.13a.689.689 0 10.941-.94V2.29h-.69z"></path>
                                    </g>
                                    <defs>
                                      <clipPath>
                                        <path d="M0 0h8.293v8.293H0z" transform="translate(0 .218)"></path>
                                      </clipPath>
                                    </defs>
                                  </svg>
                                  <p class="time-text"><%= time_ago_in_words(listing.created_at) %></p>
                                </div>
                              </div>
                            </div>
                            <div class="premium-badge">
                              <div class="premium-badge-inner">
                                <svg class="premium-icon" height="12" width="12" viewBox="0 0 10 9" xmlns="http://www.w3.org/2000/svg">
                                  <title>Premium Icon</title>
                                  <path d="M5.593 1.7a.85.85 0 10-.838.001l-.004.008c-.28.581-.666 1.414-1.264 1.727-.49.257-1.196.128-1.72.032a.638.638 0 10-.752.672l1.253 3.237c.19.491.663.815 1.19.815h3.43c.526 0 .999-.324 1.19-.815L9.33 4.14a.638.638 0 10-.752-.691c-.535.07-1.226.158-1.72-.1-.586-.307-.979-1.082-1.266-1.649z"></path>
                                </svg>Premium
                              </div>
                            </div>
                          </div>
                          <div class="listing-image-container">
                            <div class="listing-image-wrapper">
                              <div class="listing-image-overlay"></div>
                              <div class="listing-image">
                                <% if listing.images.any? %>
                                  <img src="<%= listing.images.first.url %>" loading="lazy" class="listing-main-image" />
                                <% else %>
                                  <img src="/images/placeholder.jpg" loading="lazy" class="listing-main-image" />
                                <% end %>
                              </div>
                              <div class="listing-image-count">
                                <span class="image-count-wrapper">
                                  <svg class="camera-icon" height="12" width="12" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <title>Camera Icon</title>
                                    <path d="M9.3 4h5.4l1.647 1.778H19.2c.99 0 1.8.8 1.8 1.778v10.666C21 19.2 20.19 20 19.2 20H4.8c-.99 0-1.8-.8-1.8-1.778V7.556c0-.978.81-1.778 1.8-1.778h2.853L9.3 4zM12 17.333c2.484 0 4.5-1.99 4.5-4.444 0-2.453-2.016-4.445-4.5-4.445s-4.5 1.992-4.5 4.445c0 2.453 2.016 4.444 4.5 4.444zm0-1.777c1.491 0 2.7-1.194 2.7-2.667 0-1.473-1.209-2.667-2.7-2.667s-2.7 1.194-2.7 2.667c0 1.473 1.209 2.667 2.7 2.667z"></path>
                                  </svg>
                                  <span class="image-count"><%= listing.images.count %></span>
                                </span>
                              </div>
                            </div>
                          </div>
                          <div class="listing-details">
                            <div class="listing-main-details">
                              <div class="listing-location-info">
                                <div class="location-wrapper">
                                  <svg class="location-icon" height="19" width="19" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <title>Location Icon</title>
                                    <path d="M14.004 21.99a.87.87 0 00.142.01c.45 0 .865-.29 1.032-.739l6.688-17.648a1.218 1.218 0 00-.245-1.268 1.072 1.072 0 00-1.201-.261L3.7 9.144c-.47.199-.756.71-.69 1.239.064.534.463.953.966 1.019l8.057 1.063 1.008 8.504c.062.532.459.953.963 1.021z"></path>
                                  </svg>
                                  <p class="location-text">
                                    <%= listing.category.name %> dans <%= listing.location&.city || 'Non précisé' %>
                                  </p>
                                </div>
                              </div>
                              <p class="listing-title" title="<%= listing.title %>"><%= listing.title %></p>
                              
                              <% if listing.category.slug == 'voitures' %>
                                <div class="listing-attributes">
                                  <% if listing.respond_to?(:year) && listing.year.present? %>
                                    <span class="attribute-item">
                                      <div title="Année-Modèle" class="attribute-wrapper">
                                        <div class="attribute-separator"></div>
                                        <span class="attribute-text"><%= listing.year %></span>
                                      </div>
                                    </span>
                                  <% end %>
                                  
                                  <% if listing.respond_to?(:transmission) && listing.transmission.present? %>
                                    <span class="attribute-item">
                                      <div title="Boite de vitesses" class="attribute-wrapper">
                                        <div class="attribute-separator"></div>
                                        <span class="attribute-text"><%= listing.transmission %></span>
                                      </div>
                                    </span>
                                  <% end %>
                                  
                                  <% if listing.respond_to?(:fuel_type) && listing.fuel_type.present? %>
                                    <span class="attribute-item">
                                      <div title="Type de carburant" class="attribute-wrapper">
                                        <div class="attribute-separator"></div>
                                        <span class="attribute-text"><%= listing.fuel_type %></span>
                                      </div>
                                    </span>
                                  <% end %>
                                </div>
                              <% end %>
                            </div>
                            <div class="listing-price-container">
                              <div class="price-wrapper">
                                <div class="price-inner">
                                  <p class="price-text">
                                    <span class="price-amount">
                                      <span dir="auto" class="price-value"><%= number_with_delimiter(listing.price) %></span>
                                      <span class="price-currency">DH</span>
                                    </span>
                                  </p>
                                </div>
                              </div>
                            </div>
                          </div>
                        </a>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
              <button aria-label="Annonce suivante" class="carousel-next-button">
                <svg class="carousel-arrow-icon" height="19" width="19" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <title>Annonce suivante</title>
                  <path d="M5.027 12.823A1.03 1.03 0 014 11.796a1.03 1.03 0 011.027-1.027h11.47l-5.001-5.02A1.023 1.023 0 1112.943 4.3l6.757 6.777c.4.4.4 1.047 0 1.448l-6.767 6.767c-.4.4-1.047.4-1.448 0-.4-.4-.4-1.058 0-1.459l5.011-5.01H5.026z"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
